# ─────────────────────────────────────────
#  Finanzza — Backend Environment Variables
# ─────────────────────────────────────────
#  Copie este arquivo para .env e preencha os valores.
#  NUNCA commite o arquivo .env no Git.

# Credenciais de acesso ao sistema (login da família)
APP_USER=piazza
APP_PASSWORD=dudu2203

# Chave secreta para assinar os tokens JWT — troque por uma string longa e aleatória
# Gere uma com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque_por_uma_chave_secreta_longa_e_aleatoria

# Porta do servidor (Railway injeta automaticamente em produção)
PORT=3001

# Origins permitidas pelo CORS — separe múltiplos por vírgula
# Em produção: coloque a URL exata do seu frontend na Vercel
ALLOWED_ORIGINS=http://localhost:5173
# Exemplo produção:
# ALLOWED_ORIGINS=https://finanzza.vercel.app,https://finanzza-piazza.vercel.app
