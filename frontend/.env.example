# ──────────────────────────────────────────
#  Finanzza — Frontend Environment Variables
# ──────────────────────────────────────────
#  Para desenvolvimento local: NÃO é necessário criar este arquivo.
#  O Vite faz proxy automático para localhost:3001.
#
#  Para produção (Vercel): crie um arquivo .env.production
#  com a variável abaixo apontando para o backend no Railway.

# URL base da API (sem barra final)
# Deixe vazio em dev — o proxy do Vite cuida disso.
# Em produção: coloque a URL do seu backend no Railway + /api
VITE_API_URL=https://SEU-PROJETO.up.railway.app/api
